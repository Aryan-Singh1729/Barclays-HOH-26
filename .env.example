# --- LLM Provider ---
# Supported: "groq" or "gemini" or "deepseek" or "cerebras" or "mistral" or "nvidia" or "llamacpp"
LLM_PROVIDER=groq

# Optional model override (leave blank to use provider default)
# Groq default: llama-3.3-70b-versatile
# Gemini default: gemini-2.5-flash
# Openrouter default: deepseek/deepseek-chat
# cerebras default: qwen-3-235b-a22b-instruct-2507
# default mistral-large-latest   # or mistral-small-latest, open-mistral-nemo
# good enough deepseek model: deepseek/deepseek-chat-v3.1, deepseek/deepseek-v3.2
# LLM_MODEL=

# --- API Keys ---
# Groq: supply one or more API keys (comma-separated) for automatic
# key hopping on 429 rate limits. Either variable name works.
GROQ_API_KEY=gsk_key1,gsk_key2,gsk_key3
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cerebras — https://cloud.cerebras.ai (free tier: 14,400 req/day, 1M tokens/day)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Mistral AI (console.mistral.ai)
MISTRAL_API_KEY=your_key_here

# NVIDIA NIM (build.nvidia.com) — OpenAI-compatible endpoint
# LLM_PROVIDER=nvidia
# LLM_MODEL=deepseek-ai/deepseek-v3.1        # recommended — best reasoning
# LLM_MODEL=meta/llama-3.3-70b-instruct    # lighter alternative
# LLM_MODEL=mistralai/mistral-large-latest  # Mistral via NIM
# LLM_MODEL=qwen/qwen3-235b-a22b           # largest free option
NVIDIA_API_KEY=your_key_here

# llama.cpp local server (llama-server.exe)
# LLM_PROVIDER=llamacpp
# LLAMACPP_HOST=http://localhost:8080   # default; change for LAN/remote host
# No API key required — model is set via the llama-server launch command

# --- Database ---
DB_PATH=data/aml_synthetic.db
